function calcScores(){
  const sd=gDate();const {w1=0,w2=0,w3=0,w4=0,w5=0,w6=0,w7=0,w8=0,w9=0,w10=0,w11=0,w12=0,w13=0,w14=0,w15=0,w16=0,w17=0,w18=0,w19=0,w20=0,w21=0,w22=0,w23=0}=L;
  let dh=0;for(let i=0;i<sd.length;i++){dh=((dh<<5)-dh)+sd.charCodeAt(i);dh|=0;}
  const off=Math.abs(dh)%100;const dateObj=new Date(sd);const dom=dateObj.getDate();const moy=dateObj.getMonth();
  
  if(mode==='powerball'){
    const res=[];
    for(let n=1;n<=69;n++){
      // ✅ FIX 1: Corrección en rango de Powerball
      const sN=((n-1+off)%69)+1;
      const fg=PBD.white_freq[sN]||1,da=PBD.white_debt[sN]||0;
      const eW4=Math.max(w4,18);const due=Math.min(da/30,2.0)*50;const pB=n%2!==0?10:5;
      let wkR=0;lwN.forEach(win=>{if(n===win)wkR+=50;if(n===win+1||n===win-1)wkR+=30;});
      let sc=(fg*100*(w1/10))+(due*(eW4/100))+(pB*(w8/10))+(wkR*(w23/100));
      if(gM)sc+=(Math.cos(n*0.1)*30+30)*(w19/10);if(isNaN(sc))sc=0;
      res.push({num:n,score:sc,fg,f30:fg,f7:fg,da,co:50,vol:50,mom:50,cyc:50,w23b:wkR,inM440:false,termLeak:false,hasLS:false});
    }
    return res.sort((a,b)=>b.score-a.score);
  }
  
  const df=mode==='new-york'?NYD:mode==='georgia'?GAD:RD;
  const tF={};for(let n=0;n<100;n++){const t=n%10,sN=(n+off)%100;tF[t]=(tF[t]||0)+((df.freq_7)[sN]||0);}
  const mxT=Math.max(...Object.values(tF))||1;
  let eF=0,oF=0;for(let i=0;i<100;i++){const sI=(i+off)%100;if(i%2===0)eF+=(df.freq_7)[sI]||0;else oF+=(df.freq_7)[sI]||0;}
  const pT=eF+oF||1;const res=[];
  
  for(let n=0;n<100;n++){
    const sN=(n+off)%100;
    const fg=(df.freq_global)[sN]||0,f30=(df.freq_30)[sN]||0,f7=(df.freq_7)[sN]||0;
    const da=(df.days_absent)[sN]||0,co=((df.consistency)[sN]||0)/MC*100;
    let tS=(tF[n%10]/mxT)*100;
    if(mode==='new-york')tS+=[1,5,7].includes(n%10)?32:2;
    else if(mode==='florida')tS+=[7,1,5,2,8].includes(n%10)?28:5;
    else if(mode==='georgia')tS+=[3,6,9].includes(n%10)?35:8;
    const cool=Math.min(f7/5.0,1.0)*100;
    const parS=(n%2===0)?(oF/pT)*100:(eF/pT)*100;
    const volS=Math.max(0,100-Math.abs(f7-f30)*20);
    let momS=(f7*0.7+f30*0.3)*20;
    if(mode==='georgia'&&dom>=8&&dom<=14)momS+=30;
    const cycS=(Math.sin((n+off)/10)+1)*50;const bonS=f7>2.0?100:0;const dblS=n%11===0?100:0;
    const wb=wB[n]||0;const mapS=M440.includes(n)?100:0;const snwS=(n%7===0||n<20)?80:0;
    let atS=0;Object.entries(LA).forEach(([b,t])=>{if(t.includes(n))atS+=50;});
    const qS=LQ.find(q=>q.includes(n))?40:0;const genS=gM?(Math.sin(n*0.5+off)*50+50):0;
    let mAff=0;
    if(mode==='new-york'&&[50,81,4,60,17,71].includes(n))mAff=75;
    else if(mode==='florida'&&[7,15,32,56,88,11,45,90].includes(n))mAff=80;
    else if(mode==='georgia'&&[10,20,30,40,50].includes(n))mAff=65;
    const flowS=mode==='georgia'?(Math.sin((n*0.2)+(off*0.5))*40+60):(Math.sin((n*0.1)+(off*0.2))*15);
    let tsS=0;
    if(mode!=='powerball'){
      const isNY=[50,81,4,60,17,71,33,94,23].includes(n);const isFL=[7,15,32,56,88,11,45,90,22].includes(n);const isGA=[10,20,30,40,50,36,47,77,61].includes(n);
      if(mode==='new-york')tsS=(isFL||isGA)?75:0;
      else if(mode==='florida')tsS=(isNY||isGA)?60:0;
      else if(mode==='georgia')tsS=(isNY||isFL)?50:0;
    }
    let wkR=0;lwN.forEach(win=>{
      if(n===win)wkR+=40;if(n%10===win%10)wkR+=25;
      if(n===(win+2)%100||n===(win-2+100)%100)wkR+=35;
      if(Math.floor(n/10)===Math.floor(win/10))wkR+=15;
    });
    const due=Math.min(da/30,2.0)*50;
    let eW1=Math.min(w1,5),eW4=w4,eW23=w23;
    if(mode==='florida'&&(moy===6||moy===7))eW23+=15;
    if(mode==='new-york'&&dom>=22)eW4+=15;
    let sc=(fg*(eW1/100)*100)+(f30*(w2/100)*100)+(f7*(w3/100)*100)+(due*(eW4/100))+(co*(w5/100))+(tS*(w6/100))-(cool*(w7/100))+(parS*(w8/100))+(volS*(w9/100))+(momS*(w10/100))+(cycS*(w11/100))+(bonS*(w12/100))+(dblS*(w13/100))+(wb*(w14/100))+(mapS*(w15/100))+(snwS*(w16/100))+(atS*(w17/100))+(qS*(w18/100))+(genS*(w19/100))+(mAff*(w20/100))+(flowS*(w21/100))+(tsS*(w22/100))+(wkR*(eW23/100));
    if(isNaN(sc))sc=0;
    const tL=mode==='florida'?[7,1,5,2,8].includes(n%10):mode==='new-york'?[1,5,7].includes(n%10):mode==='georgia'?[3,6,9].includes(n%10):false;
    res.push({num:n,score:sc,fg,f30,f7,da,co:(df.consistency)[sN]||0,vol:volS,mom:momS,cyc:cycS,bon:bonS,par:dblS,w23b:wkR,inM440:M440.includes(n),hasLS:atS>0,termLeak:tL});
  }
  return res.sort((a,b)=>b.score-a.score);
}

