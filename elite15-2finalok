<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Elite v15.2+ | Predicción Lotería IA Avanzada</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0F1117;--panel:#181C27;--bd:#252B3B;--hv:#1E2333;
  --txt:#f1f5f9;--txt2:#cbd5e1;--txt3:#94a3b8;
  --blue:#3b82f6;--green:#10b981;--amber:#f59e0b;--red:#ef4444;
  --purple:#8b5cf6;--delta:#00d9a0;--v15:#f97316;
  --fl:#3b82f6;--ny:#10b981;--ga:#f59e0b;--pb:#ef4444;
  font-size:14px;
}
body{background:var(--bg);color:var(--txt);font-family:system-ui,sans-serif;font-size:14px;line-height:1.5}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-thumb{background:var(--bd);border-radius:3px}

/* Números grandes — FIJO y CORRIDOS */
.num-fijo{font-size:54px;line-height:1;font-weight:900;font-family:monospace;letter-spacing:-.02em}
.num-corrido{font-size:36px;font-weight:800;font-family:monospace}
.num-cent{font-size:34px;font-weight:900;font-family:monospace;color:var(--amber)}
.mono{font-family:monospace}

/* LAYOUT */
.app{min-height:100vh;display:grid;grid-template-rows:auto 1fr auto}
.hdr{background:var(--panel);border-bottom:2px solid var(--bd);padding:10px 16px;display:flex;align-items:center;gap:9px;flex-wrap:wrap;position:sticky;top:0;z-index:50}
.brand{font-size:17px;font-weight:900;letter-spacing:-.03em}.brand span{color:var(--v15)}
.brand small{font-size:10px;background:#1e2336;color:var(--txt3);padding:2px 7px;border-radius:4px;border:1px solid var(--bd);margin-left:5px}
.mode-sw{display:flex;background:var(--bg);border:1px solid var(--bd);border-radius:10px;padding:3px;gap:2px}
.mb{padding:6px 13px;border-radius:7px;border:none;background:transparent;color:var(--txt3);font-size:12px;font-weight:900;cursor:pointer;text-transform:uppercase;transition:all .15s}
.mb.afl{background:var(--fl);color:#fff}.mb.any{background:var(--ny);color:#fff}.mb.aga{background:var(--ga);color:#111}.mb.apb{background:var(--pb);color:#fff}
.tog{width:36px;height:20px;border-radius:10px;background:var(--bd);position:relative;border:none;cursor:pointer;flex-shrink:0;transition:background .2s}
.tog.on{background:var(--purple)}.tog.ono{background:var(--amber)}
.tog::after{content:'';position:absolute;width:14px;height:14px;background:#fff;border-radius:50%;top:3px;left:3px;transition:left .2s}
.tog.on::after,.tog.ono::after{left:19px}
.hbtn{padding:6px 12px;border-radius:8px;border:1px solid var(--bd);background:transparent;color:var(--txt2);font-size:11px;font-weight:700;cursor:pointer;text-transform:uppercase;transition:all .15s}
.hbtn:hover{background:var(--hv)}.hbtn.act{background:rgba(16,185,129,.1);color:var(--green)}
.hdr-r{display:flex;align-items:center;gap:7px;margin-left:auto;flex-wrap:wrap}
.date-in{background:var(--bg);border:1px solid var(--bd);border-radius:8px;padding:6px 10px;color:var(--txt);font-size:13px;font-family:monospace;font-weight:700;outline:none}
.mbadge{font-size:11px;font-weight:900;padding:3px 8px;border-radius:6px;text-transform:uppercase}
.mfl{background:rgba(59,130,246,.15);color:var(--blue);border:1px solid rgba(59,130,246,.3)}
.mny{background:rgba(16,185,129,.15);color:var(--green);border:1px solid rgba(16,185,129,.3)}
.mga{background:rgba(245,158,11,.15);color:var(--amber);border:1px solid rgba(245,158,11,.3)}
.mpb{background:rgba(239,68,68,.15);color:var(--red);border:1px solid rgba(239,68,68,.3)}

/* BODY */
.body{display:grid;grid-template-columns:300px 1fr;overflow:hidden;height:calc(100vh - 58px)}
.sb{background:var(--panel);border-right:1px solid var(--bd);overflow-y:auto;padding:10px;display:flex;flex-direction:column;gap:8px}
.main{overflow-y:auto;display:flex;flex-direction:column;gap:10px;padding:12px}
.sp{background:var(--bg);border:1px solid var(--bd);border-radius:12px;padding:11px}
.stit{font-size:11px;font-weight:900;color:var(--txt3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px;display:flex;align-items:center;justify-content:space-between}
.sdot{width:7px;height:7px;border-radius:50%;margin-right:5px;display:inline-block;flex-shrink:0}

/* ALERTS */
.alert-box{padding:10px 12px;border-radius:10px;margin-bottom:10px;font-size:12px;border:1px solid;display:flex;align-items:center;gap:8px}
.alert-success{background:rgba(16,185,129,.1);border-color:rgba(16,185,129,.3);color:var(--green)}
.alert-warning{background:rgba(245,158,11,.1);border-color:rgba(245,158,11,.3);color:var(--amber)}
.alert-error{background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.3);color:var(--red)}
.alert-info{background:rgba(59,130,246,.1);border-color:rgba(59,130,246,.3);color:var(--blue)}

/* SLIDERS */
.wr{display:flex;align-items:center;gap:5px;margin-bottom:4px}
.wr label{font-size:11px;color:var(--txt2);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.wr input[type=range]{flex:1.2;accent-color:var(--blue);height:3px}
.wv{font-size:11px;font-weight:700;min-width:30px;text-align:right;color:var(--blue);font-family:monospace}
.wtot{font-size:11px;font-weight:900;padding:2px 6px;border-radius:4px}
.wok{background:rgba(16,185,129,.1);color:var(--green)}.werr{background:rgba(239,68,68,.1);color:var(--red)}

/* NAV */
.navt{display:flex;flex-direction:column;gap:2px}
.nt{padding:8px 12px;border-radius:8px;border:none;background:transparent;color:var(--txt3);font-size:12px;font-weight:700;cursor:pointer;text-align:left;transition:all .15s}
.nt:hover{background:var(--bd)}.nt.act{background:var(--hv);color:var(--txt);font-size:13px}

.mpbar-bg{height:6px;background:var(--bd);border-radius:3px;overflow:hidden}
.mpbar-f{height:100%;border-radius:3px;transition:width .5s}

.mg5{display:grid;grid-template-columns:repeat(5,1fr);gap:4px}
.mc{text-align:center;padding:6px 2px;border-radius:7px;background:var(--hv);border:1px solid transparent}
.mc.hot{border-color:var(--amber);background:rgba(245,158,11,.08)}
.mc .mn{font-size:13px;font-weight:800;font-family:monospace}
.mc .mv{font-size:9px;color:var(--txt3);margin-top:1px}

.pcell{display:flex;flex-direction:column;align-items:center;padding:5px 2px;border-radius:7px;border:1px solid var(--bd)}
.pcell.intop{border-color:rgba(245,158,11,.5);background:rgba(245,158,11,.07)}
.pcell .pn{font-size:13px;font-weight:900;font-family:monospace}
.syncbar{height:5px;background:var(--bg);border-radius:3px;overflow:hidden;margin:5px 0}
.syncf{height:100%;border-radius:3px;animation:syncp 2s ease-in-out infinite alternate}
@keyframes syncp{from{width:20%}to{width:99%}}

/* FORECAST CARDS */
.fcg2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.fcg3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.fcard{background:var(--panel);border:1px solid var(--bd);border-radius:16px;overflow:hidden}
.fcard-fl{border-top:4px solid var(--fl)}.fcard-ny{border-top:4px solid var(--ny)}
.fcard-ga{border-top:4px solid var(--ga)}.fcard-pb{border-top:4px solid var(--pb)}
.fch{padding:9px 14px;border-bottom:1px solid var(--bd);display:flex;align-items:center;justify-content:space-between;background:rgba(0,0,0,.15)}
.fcl{font-size:13px;font-weight:900;text-transform:uppercase;letter-spacing:.05em;display:flex;align-items:center;gap:6px}
.fdot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.fcb{padding:14px}
.fcr{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.fcr:last-child{margin-bottom:0;padding-top:10px;border-top:1px solid var(--bd)}
.frl{font-size:11px;font-weight:900;color:var(--txt3);text-transform:uppercase;letter-spacing:.04em;min-width:56px}
.ftag{font-size:10px;font-weight:700;padding:2px 7px;border-radius:5px}
.ft-g{background:rgba(16,185,129,.1);color:var(--green)}.ft-a{background:rgba(245,158,11,.1);color:var(--amber)}
.ft-d{background:rgba(0,217,160,.1);color:var(--delta)}.ft-p{background:rgba(139,92,246,.1);color:var(--purple)}
.ft-m{background:rgba(59,130,246,.1);color:var(--blue)}.ft-v{background:rgba(249,115,22,.15);color:var(--v15)}
.fcf{padding:7px 14px;background:rgba(0,0,0,.15);border-top:1px solid var(--bd);display:flex;align-items:center;justify-content:space-between}
.fcode{font-size:15px;font-weight:900;font-family:monospace;color:var(--txt2)}

/* MODO SWITCH PARLÉS */
.pmode-sw{display:flex;background:rgba(0,0,0,.3);border:1px solid var(--bd);border-radius:9px;padding:3px;gap:2px;flex-wrap:wrap}
.pmbtn{padding:6px 12px;border-radius:7px;border:none;background:transparent;color:var(--txt3);font-size:11px;font-weight:900;cursor:pointer;text-transform:uppercase;transition:all .15s;white-space:nowrap}
.pmbtn.active{background:var(--green);color:#fff;box-shadow:0 2px 8px rgba(16,185,129,.3)}
.pmbtn:hover:not(.active){background:var(--hv);color:var(--txt2)}

/* PARLÉS DINÁMICO */
.pag{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;padding:8px}
.pac{padding:8px;border-radius:9px;border:1px solid var(--bd);background:var(--bg);position:relative;overflow:hidden;transition:transform .15s}
.pac:hover{transform:scale(1.02)}
.pac.v-cor{background:rgba(249,115,22,.07);border-color:rgba(249,115,22,.5)}
.pac.v-fam{background:rgba(139,92,246,.06);border-color:rgba(139,92,246,.35)}
.pac.v-esp{background:rgba(16,185,129,.05);border-color:rgba(16,185,129,.3)}
.pac.v-syn{background:rgba(59,130,246,.05);border-color:rgba(59,130,246,.28)}
.pac.v-fil{background:rgba(100,116,139,.04);border-color:rgba(100,116,139,.2)}
.pstripe{position:absolute;top:0;left:0;width:4px;height:100%}
.pnums{font-size:22px;font-weight:900;font-family:monospace;color:var(--txt);letter-spacing:.02em;line-height:1.1}
.pnums .sep{font-size:18px;color:var(--txt3);font-weight:300;margin:0 2px}
.ptag{font-size:9px;font-weight:900;padding:2px 5px;border-radius:3px;text-transform:uppercase;margin-right:3px}
.pt-cor{background:rgba(249,115,22,.15);color:var(--v15)}
.pt-fam{background:rgba(139,92,246,.12);color:var(--purple)}
.pt-esp{background:rgba(16,185,129,.12);color:var(--green)}
.pt-syn{background:rgba(59,130,246,.12);color:var(--blue)}
.pt-fil{background:rgba(100,116,139,.1);color:var(--txt3)}
.prank{font-size:10px;font-weight:900;color:var(--txt3);text-transform:uppercase;margin-bottom:4px}
.pscore{font-size:12px;font-weight:700;font-family:monospace;text-align:right;margin-top:4px}

/* CANDADOS */
.cand-group{background:rgba(0,0,0,.25);border:1px solid var(--bd);border-radius:14px;padding:16px;margin-bottom:10px}
.cand-hdr{display:flex;align-items:center;gap:12px;margin-bottom:14px}
.cand-icon{width:38px;height:38px;background:var(--green);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.cand-title{font-size:15px;font-weight:900;color:var(--txt);text-transform:uppercase;letter-spacing:.06em}
.cand-sub{font-size:11px;color:var(--txt3);font-weight:700;text-transform:uppercase;margin-top:2px}
.cand-nums{display:flex;flex-wrap:wrap;gap:10px;padding:14px;background:var(--bg);border-radius:10px;border:1px solid var(--bd)}
.cand-ball{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:900;font-family:monospace;border:2px solid var(--bd);background:rgba(255,255,255,.05);color:var(--txt);transition:all .2s;cursor:default}
.cand-ball:hover{transform:scale(1.08)}
.cand-ball.hot{border-color:var(--amber);background:rgba(245,158,11,.12);color:var(--amber);box-shadow:0 0 14px rgba(245,158,11,.25)}
.cand-ball.top3{border-color:var(--green);background:rgba(16,185,129,.1);color:var(--green);box-shadow:0 0 10px rgba(16,185,129,.2)}
.cand-pairs{display:grid;grid-template-columns:repeat(4,1fr);gap:5px;margin-top:9px}
.cand-pair{padding:6px 8px;border-radius:7px;border:1px solid rgba(16,185,129,.25);background:rgba(16,185,129,.06);display:flex;align-items:center;justify-content:center;gap:6px}
.cand-pair-n{font-family:monospace;font-size:15px;font-weight:900;color:var(--txt)}
.cand-pair-sep{color:var(--txt3);font-size:14px;font-weight:300}

/* TABLE */
.dtab{width:100%;border-collapse:collapse;font-size:13px}
.dtab th{font-size:10px;font-weight:900;color:var(--txt3);text-transform:uppercase;letter-spacing:.06em;padding:8px 10px;border-bottom:1px solid var(--bd);text-align:left;background:rgba(0,0,0,.18);white-space:nowrap}
.dtab td{padding:8px 10px;border-bottom:1px solid var(--bd);color:var(--txt2);font-size:13px}
.dtab tr:last-child td{border-bottom:none}.dtab tr:hover td{background:rgba(255,255,255,.02)}
.dtab .num-cell{font-size:17px;font-weight:900;font-family:monospace;color:var(--txt)}
.sbw{display:flex;align-items:center;gap:5px}
.sbb{height:5px;border-radius:2px;min-width:0}
.tsm{font-size:9px;font-weight:900;padding:2px 5px;border-radius:3px}
.tel{background:rgba(245,158,11,.1);color:var(--amber)}.tdu{background:rgba(239,68,68,.1);color:var(--red)}
.tw3{background:rgba(139,92,246,.1);color:var(--purple)}.tpr{background:rgba(0,217,160,.1);color:var(--delta)}
.tmx{background:rgba(59,130,246,.1);color:var(--blue)}.tvec{background:rgba(249,115,22,.15);color:var(--v15)}

/* MATRIX */
.matg{display:grid;grid-template-columns:repeat(10,1fr);gap:3px}
.mcel{aspect-ratio:1;display:flex;flex-direction:column;align-items:center;justify-content:center;border-radius:5px;border:1px solid var(--bd);font-family:monospace;cursor:default;transition:transform .1s}
.mcel:hover{transform:scale(1.1);z-index:5}
.mcel .mcn{font-size:13px;font-weight:900}.mcel .mcs{font-size:8px;opacity:.6}
.mcel.top{box-shadow:0 0 9px rgba(245,158,11,.35)}

/* DEBT */
.dch{display:flex;align-items:flex-end;gap:5px;height:180px;padding:0 4px}
.dcbc{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px}
.dcb{width:100%;border-radius:3px 3px 0 0;min-height:4px}
.dcn{font-size:11px;font-weight:700;font-family:monospace;color:var(--txt3)}.dcv{font-size:9px;color:var(--txt3)}

/* DATA LAB */
.dlg{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.dlf{background:var(--bg);border:1px solid var(--bd);border-radius:12px;padding:13px}
.dlin{width:100%;background:rgba(0,0,0,.3);border:1px solid var(--bd);border-radius:8px;padding:9px 11px;font-size:16px;font-family:monospace;font-weight:700;color:var(--txt);outline:none;margin-bottom:8px}
.dlin:focus{border-color:var(--green)}
.dlsel{width:100%;background:rgba(0,0,0,.3);border:1px solid var(--bd);border-radius:8px;padding:9px 11px;font-size:13px;color:var(--txt);outline:none;margin-bottom:8px}
.dlbtn{width:100%;background:var(--green);color:#fff;border:none;border-radius:9px;padding:11px;font-size:13px;font-weight:900;text-transform:uppercase;cursor:pointer}
.dlhi{background:var(--hv);border:1px solid var(--bd);border-radius:9px;padding:9px 11px;display:flex;align-items:center;justify-content:space-between;margin-bottom:5px}
.dlnb{width:30px;height:30px;border-radius:7px;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.2);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:900;color:var(--green);font-family:monospace}

/* AI */
.aiw{background:linear-gradient(135deg,#1e293b,#0f172a);border-radius:15px;overflow:hidden}
.aibot{align-self:flex-start;background:rgba(139,92,246,.15);padding:10px 13px;border-radius:13px 13px 13px 3px;font-size:13px;max-width:92%;border:1px solid rgba(139,92,246,.2);color:#e0d7ff;line-height:1.7}
.aibot strong{color:#fff}
.aiuser{align-self:flex-end;background:rgba(255,255,255,.08);padding:9px 13px;border-radius:13px 13px 3px 13px;font-size:13px;max-width:80%;border:1px solid rgba(255,255,255,.05)}
.aiqb{background:var(--panel);border:1px solid var(--bd);border-radius:10px;padding:10px;cursor:pointer;text-align:left;transition:all .15s}
.aiqb:hover{border-color:var(--purple);background:rgba(139,92,246,.06)}
.aiqb .aiq-lbl{font-size:10px;font-weight:900;color:var(--txt3);text-transform:uppercase;margin-bottom:3px}
.aiqb .aiq-txt{font-size:13px;font-weight:700;color:var(--txt)}

/* RECALIBRACIÓN */
.rp{background:var(--bg);border:1px solid rgba(239,68,68,.3);border-radius:12px;padding:11px}
.rin{width:100%;background:rgba(0,0,0,.3);border:1px solid var(--bd);border-radius:8px;padding:8px 11px;font-size:15px;font-family:monospace;font-weight:700;color:var(--txt);outline:none;margin-bottom:6px}
.rin:focus{border-color:var(--red)}
.rbtn{width:100%;background:var(--red);color:#fff;border:none;border-radius:8px;padding:9px;font-size:12px;font-weight:900;text-transform:uppercase;cursor:pointer}

/* MISC */
.svi{background:var(--bg);border:1px solid var(--bd);border-radius:8px;padding:8px 11px;display:flex;align-items:center;justify-content:space-between;margin-bottom:4px}
.dbtn{background:transparent;border:none;color:var(--txt3);cursor:pointer;font-size:14px}.dbtn:hover{color:var(--red)}
.optbtn{width:100%;background:var(--hv);border:1px solid var(--bd);color:var(--txt);border-radius:9px;padding:10px;font-size:12px;font-weight:900;text-transform:uppercase;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:5px;transition:all .15s}
.optbtn:hover{background:#404a62}
.optmsg{font-size:11px;color:var(--green);margin-top:5px;padding:6px 9px;background:rgba(16,185,129,.07);border-radius:6px;display:none}
.lsc{display:flex;align-items:center;gap:5px;margin-bottom:5px;padding:6px 8px;background:rgba(0,0,0,.2);border-radius:7px;border:1px solid rgba(139,92,246,.12)}
.prow{display:flex;gap:7px}.ph{flex:1}
.phl{display:flex;justify-content:space-between;font-size:10px;font-weight:900;margin-bottom:3px}
.phbg{height:6px;background:var(--bg);border-radius:3px;overflow:hidden}.phf{height:100%;border-radius:3px}
.decg{display:grid;grid-template-columns:repeat(5,1fr);gap:4px}
.dcc{display:flex;flex-direction:column;align-items:center;gap:2px}
.dcbw{width:100%;background:var(--bg);height:32px;border-radius:5px;border:1px solid var(--bd);position:relative;overflow:hidden}
.dcbf{position:absolute;bottom:0;left:0;right:0;background:rgba(59,130,246,.35)}
.dcbn{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:900}
.dclbl{font-size:9px;font-weight:700;color:var(--txt3)}
.sec{background:var(--panel);border:1px solid var(--bd);border-radius:14px;overflow:hidden}
.sech{padding:10px 14px;border-bottom:1px solid var(--bd);display:flex;align-items:center;justify-content:space-between;background:rgba(0,0,0,.12);flex-wrap:wrap;gap:6px}
.sect{font-size:13px;font-weight:900;text-transform:uppercase;letter-spacing:.05em;display:flex;align-items:center;gap:7px}
.footer{background:var(--panel);border-top:1px solid var(--bd);padding:8px 16px;display:flex;align-items:center;justify-content:space-between;font-size:10px;color:var(--txt3);font-weight:700;text-transform:uppercase;flex-wrap:wrap;gap:4px}
.fdot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:blink 2s infinite;flex-shrink:0}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.hidden{display:none}
.pb-cg{display:grid;grid-template-columns:repeat(5,1fr);gap:7px;padding:10px}
.pbc{background:var(--bg);border:1px solid var(--bd);border-radius:11px;overflow:hidden}
.pbc.best{border-color:rgba(239,68,68,.4);background:rgba(239,68,68,.04)}
.pball{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:900;font-family:monospace}
.pbw{background:rgba(255,255,255,.07);border:2px solid var(--bd);color:var(--txt)}
.pbr{background:var(--red);color:#fff}
.pb-prime{background:rgba(245,158,11,.2);border:2px solid rgba(245,158,11,.5);color:var(--amber)}

/* STATS WIDGET */
