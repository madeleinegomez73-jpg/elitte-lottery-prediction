  return result;
}

// ✨ MEJORA 3: CÁLCULO DE CONFIANZA
function calcConfidence(topNumber,allScores){
  const top5avg=allScores.slice(0,5).reduce((a,b)=>a+b.score,0)/5;
  const margin=topNumber.score-allScores[1].score;
  const consistency=topNumber.co/200;
  return Math.min(99,((margin/top5avg)*40)+(consistency*30)+(topNumber.f7*20)+(topNumber.fg*10));
}

// ✨ MEJORA 4: DETECCIÓN DE PATRONES
function detectPatterns(sc,lwN){
  const patterns={consecutivos:0,terminales:0,decenas:0,espejo:0,pares:0};
  for(let i=0;i<sc.length-1;i++){
    const diff=Math.abs(sc[i].num-sc[i+1].num);
    if(diff===1)patterns.consecutivos++;
    if(diff===10||diff===11)patterns.decenas++;
    if(sc[i].num%10===sc[i+1].num%10)patterns.terminales++;
  }
  return patterns;
}

// ✨ MEJORA 5: SISTEMA DE ALERTAS
function generateAlerts(){
  const sc=calcScoresOptimized();
  const patterns=detectPatterns(sc,lwN);
  const alerts=[];
  if(patterns.consecutivos>5)
    alerts.push({type:'warning',msg:'⚠️ Alto nivel de consecutivos detectado'});
  const highDebt=sc.filter(s=>s.da>60);
  if(highDebt.length>3)
    alerts.push({type:'warning',msg:`⚠️ ${highDebt.length} números con deuda crítica`});
