function getAffinity(a,b){
  let sc=0;const d=Math.abs(a-b);
  if(d===1||d===10||d===11)sc+=100;
  if(a%10===b%10)sc+=80;
  const aInv=(a%10)*10+Math.floor(a/10);if(b===aInv)sc+=70;
  if(Math.floor(a/10)===Math.floor(b/10))sc+=50;
  if(lwN.includes(a)&&lwN.includes(b))sc+=40;
  return sc;
}

function calcCandadoGroups(top20){
  if(mode==='powerball'||parleMode==='dynamic')return[];
  const usedNums=new Set();const groups=[];const available=[...top20];
  const count=parleMode==='candado-5'?5:10;
  const maxGroups=parleMode==='candado-5'?4:2;
  while(usedNums.size<top20.length&&groups.length<maxGroups){
    const pivot=available.find(n=>!usedNums.has(n.num));if(!pivot)break;
    usedNums.add(pivot.num);const group=[pivot];
    const partners=available.filter(n=>!usedNums.has(n.num)).sort((a,b)=>getAffinity(pivot.num,b.num)-getAffinity(pivot.num,a.num)).slice(0,count-1);
    partners.forEach(p=>{group.push(p);usedNums.add(p.num);});
    groups.push(group);
  }
  return groups;
}

function calcParles(top20){
  if(mode==='powerball')return{combos:[],groups:[]};
  const groups=calcCandadoGroups(top20);
  if(parleMode!=='dynamic'){
    const finalCombos=[];const freqMap={};
    const addC=(p1,p2,sc,tags)=>{finalCombos.push({p1,p2,combinedScore:sc,tags});freqMap[p1]=(freqMap[p1]||0)+1;freqMap[p2]=(freqMap[p2]||0)+1;};
    groups.forEach((group,gIdx)=>{
      for(let i=0;i<group.length;i++){for(let j=i+1;j<group.length;j++){
        const bonus=parleMode==='candado-10'?400:300;
        const tagName=parleMode==='candado-10'?'Fusión Inteligente':'Agrupado';
        addC(group[i].num,group[j].num,(group[i].score+group[j].score)+bonus,[`Candado #${gIdx+1}`,tagName]);
      }}
    });
    return{combos:finalCombos,groups};
  }
  const base=top20;const finalCombos=[];const freqMap={};
  const isDup=(p1,p2)=>finalCombos.some(c=>(c.p1===p1&&c.p2===p2)||(c.p1===p2&&c.p2===p1));
  // ✅ FIX 2: Mejorado control de duplicados
  const canUse=(p1,p2)=>{if(isDup(p1,p2))return false;if(p1===p2)return false;if((freqMap[p1]||0)>=2||(freqMap[p2]||0)>=2)return false;return true;};
  const addC=(p1,p2,sc,tags,cls)=>{finalCombos.push({p1,p2,combinedScore:sc,tags,cls});freqMap[p1]=(freqMap[p1]||0)+1;freqMap[p2]=(freqMap[p2]||0)+1;};
  
  for(let i=0;i<base.length;i++)for(let j=i+1;j<base.length;j++){
    const v1=base[i].num,v2=base[j].num,diff=Math.abs(v1-v2);
    if(canUse(v1,v2)&&(diff===1||diff===10||diff===11))addC(v1,v2,(base[i].score+base[j].score)+300,['Corridos','Vecindad'],'v-cor');
  }
  for(let i=0;i<base.length;i++)for(let j=i+1;j<base.length;j++){
    const v1=base[i].num,v2=base[j].num;
    if(canUse(v1,v2)&&v1%10===v2%10)addC(v1,v2,(base[i].score+base[j].score)+200,['Familia','Terminal'],'v-fam');
  }
  for(let i=0;i<base.length;i++)for(let j=i+1;j<base.length;j++){
    const v1=base[i].num,v2=base[j].num;const v1inv=(v1%10)*10+Math.floor(v1/10);
    if(canUse(v1,v2)&&v2===v1inv&&v1!==v2)addC(v1,v2,(base[i].score+base[j].score)+180,['Inverso','Espejo'],'v-esp');
  }
  for(let i=0;i<base.length;i++)for(let j=i+1;j<base.length;j++){
    const v1=base[i].num,v2=base[j].num;
    if(canUse(v1,v2)&&i<10&&j<15)addC(v1,v2,(base[i].score+base[j].score)+100,['Elite','Sync'],'v-syn');
  }
  for(let i=0;i<base.length&&finalCombos.length<24;i++)for(let j=i+1;j<base.length&&finalCombos.length<24;j++){
    const v1=base[i].num,v2=base[j].num;
    if(canUse(v1,v2))addC(v1,v2,(base[i].score+base[j].score),['Sync'],'v-fil');
  }
  return{combos:finalCombos.slice(0,24).sort((a,b)=>b.combinedScore-a.combinedScore),groups:[]};
}

function calcPBCombos(sc,reds){
